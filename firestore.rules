rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Exams ───────────────────────────────────────────────────────────────
    match /exams/{examId} {
      allow get:  if resource.data.isPublished == true || request.auth != null;
      allow list: if true;
      allow write: if request.auth != null;

      match /questions/{questionId} {
        allow read: if (
            get(/databases/$(database)/documents/exams/$(examId)).data.isPublished == true
          ) || request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // ── Activation codes ────────────────────────────────────────────────────
    match /activationCodes/{codeId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── User courses ────────────────────────────────────────────────────────
    match /userCourses/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null;
    }

    // ── Users + subcollections ───────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // exam history / results (ระบบเดิม)
      match /{subcol}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Flash Card progress (แยก rule เพื่อความชัดเจน)
      match /fcProgress/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Flash Card deck stats (aggregate counter ต่อ deck ต่อ user)
      match /fcDeckStats/{deckId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Results ─────────────────────────────────────────────────────────────
    match /results/{resultId} {
      allow create: if true;
      allow get:    if true;
      allow list:   if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Flash Card Decks ─────────────────────────────────────────────────────
    // published deck → อ่านได้ทุกคน  |  write → auth only (admin)
    match /flashcardDecks/{deckId} {
      allow read:  if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Flash Cards ──────────────────────────────────────────────────────────
    // published card → อ่านได้ทุกคน  |  write → auth only
    match /flashcards/{cardId} {
      allow read:  if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }

    // ── MOPH Focus ───────────────────────────────────────────────────────────
    // อ่านได้เมื่อ login แล้ว  |  write → auth only (admin)
    match /mophFocus/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

  }
}
