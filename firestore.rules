rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Exams ───────────────────────────────────────────────────────────────
    match /exams/{examId} {
      allow get:  if resource.data.isPublished == true || request.auth != null;
      allow list: if true;
      allow write: if request.auth != null;

      match /questions/{questionId} {
        allow read: if (
            get(/databases/$(database)/documents/exams/$(examId)) != null &&
            get(/databases/$(database)/documents/exams/$(examId)).data.isPublished == true
          ) || request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // ── Activation codes ────────────────────────────────────────────────────
    // Authenticated users may query codes (to look up & validate).
    // Only authenticated users can write (admin panel).
    match /activationCodes/{codeId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── User courses ────────────────────────────────────────────────────────
    // Users can read/create their own course records.
    // Admins (any authenticated user for now) can list all.
    match /userCourses/{docId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null;
    }

    // ── Users (profile cache) ───────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Results ─────────────────────────────────────────────────────────────
    match /results/{resultId} {
      allow create: if true;
      allow get:    if true;
      allow list:   if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
