{
  "indexes": [

    // ── Exams ────────────────────────────────────────────────────────────────
    {
      "collectionGroup": "exams",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPublished", "order": "ASCENDING"  },
        { "fieldPath": "createdAt",   "order": "DESCENDING" }
      ]
    },

    // ── Results ──────────────────────────────────────────────────────────────
    {
      "collectionGroup": "results",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "examId",      "order": "ASCENDING"  },
        { "fieldPath": "submittedAt", "order": "DESCENDING" }
      ]
    },

    // ── Flash Card Decks ──────────────────────────────────────────────────────
    // getPublishedDecks(): isPublished + order
    {
      "collectionGroup": "flashcardDecks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPublished", "order": "ASCENDING" },
        { "fieldPath": "order",       "order": "ASCENDING" }
      ]
    },

    // ── Flash Cards ───────────────────────────────────────────────────────────
    // getCardsByDeck(): isPublished + deckIds(array-contains)
    // (client sorts by deckOrder[slug] after fetch — no compound sort needed)
    {
      "collectionGroup": "flashcards",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPublished", "order": "ASCENDING"   },
        { "fieldPath": "deckIds",     "arrayConfig": "CONTAINS" }
      ]
    },

    // ── MOPH Focus ────────────────────────────────────────────────────────────
    // getPublishedMOPHFocus(): isPublished + publishedDate DESC
    {
      "collectionGroup": "mophFocus",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isPublished",   "order": "ASCENDING"  },
        { "fieldPath": "publishedDate", "order": "DESCENDING" }
      ]
    }

  ],
  "fieldOverrides": []
}
